# SCRIPT PER CONTARE I CAMPIONI REALI DALLE DIRECTORY
count_real_samples <- function(base_path = "D:/AcMet/3AcMet/Epigenetic_Analysis/Methylation/GDCdata") {
cat("=== CONTEGGIO CAMPIONI REALI DALLE DIRECTORY ===\n\n")
projects <- c("TCGA-COAD", "TCGA-LUAD", "TCGA-PRAD")
results <- list()
for (proj in projects) {
cat("Analizzo", proj, "...\n")
# Percorso alla directory dei campioni
samples_path <- file.path(base_path, proj, "DNA_Methylation", "Methylation_Beta_Value")
if (!dir.exists(samples_path)) {
cat("❌ Directory non trovata:", samples_path, "\n")
next
}
# Lista delle directory (ogni directory è un campione)
sample_dirs <- list.dirs(samples_path, full.names = FALSE, recursive = FALSE)
# Filtra solo le directory che sembrano UUID (opzionale)
uuid_pattern <- "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$"
sample_dirs <- sample_dirs[grepl(uuid_pattern, sample_dirs)]
cat("   Directory UUID trovate:", length(sample_dirs), "\n")
# Conta i file .txt effettivi
txt_files <- list.files(
path = samples_path,
pattern = "\\.sesame\\.level3betas\\.txt$",
recursive = TRUE,
full.names = FALSE
)
cat("   File .txt trovati:", length(txt_files), "\n")
results[[proj]] <- list(
sample_dirs = length(sample_dirs),
txt_files = length(txt_files),
sample_ids = sample_dirs
)
}
# RIASSUNTO
cat("\n", strrep("=", 50), "\n")
cat("RIASSUNTO CAMPIONI REALI\n")
cat(strrep("=", 50), "\n")
total_samples <- 0
for (proj in projects) {
if (proj %in% names(results)) {
n <- results[[proj]]$sample_dirs
total_samples <- total_samples + n
cat(proj, ":", n, "campioni\n")
}
}
cat("TOTALE:", total_samples, "campioni\n")
return(results)
}
# Esegui il conteggio
real_samples <- count_real_samples()
View(real_samples)
